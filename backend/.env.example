# Server Configuration
PORT=3001

# OP_NET RPC
# Production: https://testnet.opnet.org/api/v1/json-rpc
OPNET_RPC=https://testnet.opnet.org/api/v1/json-rpc

# Proxy (Optional)
# If you are in a geo-restricted area, provide a proxy URL
# PROXY_URL=http://your-proxy-server:port

# Administrative (Optional - for contract deployment if not using UI)
# ADMIN_PRIVATE_KEY=your_hex_private_key
